# =============================================================================
# MariaDB
# =============================================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=eglise_app
DB_PASSWORD=change-me-strong-password
DB_NAME=eglise

# =============================================================================
# Session (HMAC cookies) — OBLIGATOIRE en production (min. 32 caractères aléatoires)
# Exemple : openssl rand -hex 32
# =============================================================================
SESSION_SECRET=

# Origines supplémentaires autorisées pour POST (séparées par des virgules), optionnel
# ALLOWED_ORIGINS=https://www.votredomaine.org

# =============================================================================
# Seed initial (`npm run db:seed`) — changez le mot de passe admin avant la prod
# =============================================================================
SEED_ADMIN_EMAIL=admin@cbdtogo.org
SEED_ADMIN_PASSWORD=

# Bible 100 % locale (après npm run bible:download + bible:verify)
# BIBLE_LOCAL_ONLY=1

# Tests E2E Playwright (optionnel)
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# =============================================================================
# Bible distante — optionnel (voir src/lib/bibleRemote.ts ; défaut fichier local / API interne).
# =============================================================================
# BIBLE_REMOTE_PROVIDER=
# NEXT_PUBLIC_BIBLE_REMOTE_PROVIDER=
# BIBLE_HELLOAO_TRANSLATION=
# NEXT_PUBLIC_BIBLE_HELLOAO_TRANSLATION=
# BIBLE_REMOTE_VERSION=
# NEXT_PUBLIC_BIBLE_REMOTE_VERSION=
